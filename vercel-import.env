# Copy everything BELOW the line into Vercel (Import .env or paste).
# Replace every CHANGE_ME / example host with your real values.
# Remove the EXAMPLE_NAME row in the UI before importing, or replace this whole block.
# ---------------------------------------------------------------------------

DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

AUTH_SECRET=CHANGE_ME_minimum_32_characters_use_openssl_rand_base64_32

ADMIN_PASSWORD=CHANGE_ME_your_admin_login_password

STRIPE_SECRET_KEY=sk_test_CHANGE_ME

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME

NEXT_PUBLIC_APP_URL=https://YOUR_PROJECT_NAME.vercel.app

STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME_from_stripe_webhook_dashboard

# Optional: uncomment and fill if you use Resend for the contact form
# RESEND_API_KEY=re_xxxx
# CONTACT_TO_EMAIL=you@example.com
# RESEND_FROM_EMAIL=Recchi Studio <hello@yourdomain.com>

# Optional: only if you want a username in addition to password for /admin
# ADMIN_USERNAME=
