# PostgreSQL (required). Use Neon, Supabase, Vercel Postgres, Railway, or local Postgres.
# Example (Neon): postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Admin JWT — use a long random string (32+ chars) in production
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Admin login for /admin (optional username — if set, username + password must match)
# Avoid wrapping in quotes unless your host requires it; special chars like ! are fine unquoted.
ADMIN_USERNAME=
ADMIN_PASSWORD=change-me

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook signing secret — https://dashboard.stripe.com/webhooks
# Endpoint URL: https://YOUR_DOMAIN/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# Public URL of your site (used for Stripe redirects). On Vercel set to your production URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Contact form — optional email notifications (https://resend.com)
RESEND_API_KEY=""
CONTACT_TO_EMAIL=""
# Verified domain in Resend, e.g. "Recchi Studio <hello@yourdomain.com>"
RESEND_FROM_EMAIL=""

# Product import from CSV (optional)
# Use a published Google Sheet CSV URL or any URL that returns CSV with the expected columns.
PRODUCTS_CSV_URL=""
